<% layout('layout/boilerplate.ejs') -%>


<div class="container">
    <%if(data.length==0){%>
        <div class="card mt-3">
            <h3 style="text-align: center; font-weight: bolder;">Your cart is Empty</h3>
        </div>
    <%}else{%>
        <div class="row mt-3">
            <div class="col-8">
                <div class="card">
                <% for(let cartItem of data){ %>
                        <div class="card mb-3">
                            <div class="row">
                                <div class="col-4">
                                    <img class="p-3" src="<%= cartItem.productId.image %>"style="height:150px; width: 100%;">
                                </div>
                                <div class="col-8">
                                    <h5><%= cartItem.productId.name %></h5>
                                    <p class="text-muted"><%= cartItem.productId.desc %></p>
                                    <div class="d-flex gap-2">
                                        <form action="/users/<%= cartItem.productId._id %>/cart/remove" method="post">
                                            <button class="btn btn-outline-secondary">-</button>
                                        </form>
                                        <span style="font-size: 1.4em;"><%= cartItem.quantity %></span>
                                        <form action="/users/<%= cartItem.productId._id %>/cart/add" method="post">
                                            <button class="btn btn-outline-secondary">+</button>
                                        </form>
                                    </div>
                                    <h5>$ <%= cartItem.productId.price %> </h5>
                                    <h5><%= cartItem.productId.price %>*<%= cartItem.quantity %>= <%= cartItem.productId.price*cartItem.quantity %></h5>
                                </div>
                            </div>                        
                        </div>
                <% } %>
                </div>
            </div>
            <div class="col-4">
                <div class="card">
                    <h5>Total price : <%=totalPrice %></h5>
                    <button class="btn btn-primary">Place Order</button>
                </div>
            </div>
        </div>        
    <%}%>
</div>