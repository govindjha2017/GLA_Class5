<% layout('layout/boilerplate.ejs') %>

<div class="container mt-4">
    <%if(cartData.length==0){%>
            <div class="card">
                <h4 style="text-align: center; font-weight: bolder;">Your cart is empty</h4>
            </div>
    <%}else{%>
        <div class="row">
            <div class="col-8">
                <div class="card">
                <% for(let cartItem of cartData){ %>
                    <div class="card mb-2">
                        <div class="row">
                            <div class="col-4">
                                <img src="<%= cartItem.productId.image %>"style="height:170px; width: 250px; padding:10px">
                            </div>
                            <div class="col-8">
                                <div>
                                    <h5><%= cartItem.productId.name %></h5>
                                    <p class="text-muted"><%= cartItem.productId.desc %></p>
                                    <div class="d-flex gap-2">
                                        <form action="/users/<%= cartItem.productId._id %>/cart/remove" method="post" >
                                            <button class="btn btn-outline-secondary">-</button>
                                        </form>
                                        <span  style="font-size: 1.3em;"><%= cartItem.quantity%></span>
                                        <form action="/users/<%= cartItem.productId._id %>/cart/add" method="post" >
                                            <button class="btn btn-outline-secondary">+</button>
                                        </form>
                                    </div>
                                    <h5>$ <%= cartItem.productId.price %></h5>
                                    <h6><%= cartItem.productId.price %> * <%= cartItem.quantity %>= <%= cartItem.productId.price*cartItem.quantity %></h6>
                                </div>
                            </div>
                        </div>                    
                    </div>
                <% }%>
                </div>
            </div>
            <div class="col-4">
                <div class="card">
                    <h5>Total Price = <%=totalPrice %></h5>
                    <button class="btn btn-primary mt-3">Place order</button>
                </div>
            </div>
        </div>
    <%}%>
</div>