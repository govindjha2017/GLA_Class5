<% layout("layout/boilerplate.ejs")  -%>

<div class="container d-flex flex-wrap">
    <%for(let product of products){%>
        <div class="card" style="width: 18rem;">
            <img style="height: 200px;" src="<%= product.image %>" class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title"><%=product.name %></h5>
                <h5 class="card-title">$<%=product.price %></h5>
                <p class="card-text"><%=product.desc %></p>

                <div style="display: flex; gap: 7px; justify-content: center;">
                    <%if(currUser?.role=="Seller"){%>
                        <a href="/product/<%= product._id %>/edit" class="btn btn-warning">Edit</a>
                        <form action="/products/<%=product._id%>?_method=delete" method="post">
                            <button class="btn btn-danger">Delete</button>
                        </form>
                    <%}else{%>
                       
                         <form action="/users/<%=product._id%>/cart/add" method="post" >
                            <button type="submit" class="btn btn-primary">Add to cart</button>
                         </form>
                        <a href="#" class="btn btn-success">Buy Now</a>
                    <%}%>
                </div>

        
                
            </div>
        </div>
    <%}%>
</div>